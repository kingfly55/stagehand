OPENAI_API_KEY=""
CEREBRAS_API_KEY=""
GROQ_API_KEY=""
BROWSERBASE_API_KEY=""
BRAINTRUST_API_KEY=""
ANTHROPIC_API_KEY=""
HEADLESS=false
ENABLE_CACHING=false
EVAL_MODELS="gpt-4o,claude-sonnet-4-6"
EXPERIMENTAL_EVAL_MODELS="gpt-4o,claude-sonnet-4-6,o1-mini,o1-preview"
EVAL_CATEGORIES="observe,act,combination,extract,experimental"
AGENT_EVAL_MAX_STEPS=50

# ── Playwright-native / Camoufox (Phase 5+) ───────────────────────────────────
# WebSocket URL printed by camoufox on startup.
# Run camoufox, copy the ws:// URL from its output, paste here.
CAMOUFOX_WS=""

# OpenRouter API key — preferred over OPENAI_API_KEY for Firefox/camoufox tests.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Model to use for camoufox integration tests.
# Default (if not set): google/gemini-2.5-pro
# Other good options:   openai/gpt-4.1   anthropic/claude-sonnet-4
# Full list:            https://openrouter.ai/models
STAGEHAND_MODEL="google/gemini-2.5-pro"